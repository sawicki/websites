import sites/*

# --- Cloudflare-only gate (Caddy v2) ---
(cloudflare_only) {
	@not_cloudflare not remote_ip 173.245.48.0/20 103.21.244.0/22 103.22.200.0/22 103.31.4.0/22 141.101.64.0/18 108.162.192.0/18 190.93.240.0/20 188.114.96.0/20 197.234.240.0/22 198.41.128.0/17 162.158.0.0/15 104.16.0.0/13 104.24.0.0/14 172.64.0.0/13 131.0.72.0/22 2400:cb00::/32 2606:4700::/32 2803:f800::/32 2405:b500::/32 2405:8100::/32 2a06:98c0::/29 2c0f:f248::/32

	respond @not_cloudflare "Forbidden (Cloudflare-only)" 403
}

# Catch-all for any Host on HTTP (no cert needed)
http://:80 {
	root * /var/www/landing
	file_server
	encode zstd gzip
}

fjs.cx {
	root * /var/www/landing
	file_server
	encode zstd gzip
}

eberly.xyz {
	root * /var/www/eberly.xyz
	file_server
	encode zstd gzip
}

services.fjs.app {
	root * /var/www/services.fjs.app
	file_server
	encode zstd gzip
}

adsb.fjs.app {
	redir https://services.fjs.app{uri} 308
}

sonar.fjs.app {
    root * /var/www/sonar.fjs.app
    file_server
    encode zstd gzip
}

