prompt.fjs.cx, prompt.fjs.app {
	# Set the root directory to where we put the index.html
	root * /var/www/prompt-architect

	# Enable Gzip compression for speed
	encode gzip

	# Serve the static files
	file_server
}

pbca.fjs.cx {
    root * /var/www/pbca.fjs.cx
    file_server
    encode zstd gzip

    # Basic security headers (safe for a static site + iframe embed)
    header {
        X-Content-Type-Options "nosniff"
        X-Frame-Options "SAMEORIGIN"
        Referrer-Policy "strict-origin-when-cross-origin"

        # Allow Google Maps to render inside your page (this is your page embedding Google).
        # Note: this policy is for YOUR page; it doesn't control google.com.
        Content-Security-Policy "default-src 'self'; img-src 'self' data: https:; style-src 'self' 'unsafe-inline'; script-src 'self' 'unsafe-inline'; frame-src https://www.google.com https://google.com; connect-src 'self' https:;"
    }

    # Optional: nice access log
    log {
        output file /var/log/caddy/pbca.fjs.cx.access.log
        format console
    }
}


