	import cloudflare_only

	root * /var/www/landing
	file_server
	encode zstd gzip
}

maggie.fjs.cx, maggie.fjs.app, maggie.eberly.xyz {
	root * /var/www/maggie.fjs.cx
	file_server
	encode zstd gzip
}

ty.fjs.cx, ty.eberly.xyz {
	root * /var/www/ty.fjs.cx
